@{
    ViewData["Title"] = "Сброс пароля";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        @@keyframes float {
            0%, 100% {
                transform: translateY(0) rotate(0deg);
            }

            33% {
                transform: translateY(-30px) rotate(120deg);
            }

            66% {
                transform: translateY(20px) rotate(240deg);
            }
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 2.5rem 1rem 5rem;
            position: relative;
        }

        .background {
            position: absolute;
            inset: 0;
            background: inherit;
            z-index: 0;
        }

        .animated-shape {
            position: absolute;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            filter: blur(70px);
            pointer-events: none;
        }

        .shape1 {
            width: 480px;
            height: 480px;
            top: -140px;
            right: -140px;
            animation: float 22s infinite;
        }

        .shape2 {
            width: 360px;
            height: 360px;
            bottom: -120px;
            left: -120px;
            animation: float 17s infinite reverse;
        }

        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 460px;
            margin: 1rem auto 3rem;
        }

        .logo {
            text-align: center;
            margin: 1.5rem 0 2.5rem;
        }

            .logo a {
                font-size: 2.4rem;
                font-weight: 800;
                background: linear-gradient(90deg, #ffffff, #f0f0f0);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                text-decoration: none;
            }

            .logo i {
                color: #FFD700;
                margin-right: 12px;
            }

        .card {
            background: rgba(255, 255, 255, 0.09);
            backdrop-filter: blur(12px);
            border-radius: 22px;
            padding: 2.4rem 2rem;
            border: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 20px 50px rgba(0,0,0,0.28);
        }

        .card-header {
            text-align: center;
            margin-bottom: 2.2rem;
        }

            .card-header h1 {
                color: white;
                font-size: 1.9rem;
                font-weight: 700;
                margin-bottom: 0.6rem;
            }

            .card-header p {
                color: rgba(255,255,255,0.78);
                font-size: 1rem;
            }

        .alert {
            background: rgba(255, 87, 87, 0.2);
            border: 1px solid rgba(255, 87, 87, 0.3);
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1.6rem;
            color: white;
            font-size: 0.92rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .form-group {
            margin-bottom: 1.7rem;
        }

        .form-label {
            color: white;
            font-weight: 500;
            margin-bottom: 0.6rem;
            font-size: 0.95rem;
            display: block;
        }

        .input-group {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.55);
            font-size: 1.15rem;
        }

        .password-toggle {
            position: absolute;
            right: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.55);
            cursor: pointer;
            font-size: 1.15rem;
        }

            .password-toggle:hover {
                color: #FFD700;
            }

        .form-control {
            width: 100%;
            padding: 1rem 1rem 1rem 3.3rem;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.22);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: all 0.25s ease;
        }

            .form-control:focus {
                outline: none;
                border-color: #FFD700;
                background: rgba(255,255,255,0.14);
                box-shadow: 0 0 0 3px rgba(255,215,0,0.18);
            }

            .form-control::placeholder {
                color: rgba(255,255,255,0.45);
            }

        .password-hint {
            color: rgba(255,255,255,0.55);
            font-size: 0.85rem;
            margin-top: 0.4rem;
        }

        #passwordMatch {
            color: #ff6b6b;
            font-size: 0.85rem;
            margin-top: 0.4rem;
        }

        .btn {
            width: 100%;
            padding: 1.1rem;
            background: linear-gradient(45deg, #FFD700, #FFAA00);
            border: none;
            border-radius: 12px;
            color: #1a1a2e;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
        }

            .btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 30px rgba(255,215,0,0.35);
            }

            .btn:disabled {
                opacity: 0.65;
                cursor: not-allowed;
            }

        .back-link {
            text-align: center;
            margin-top: 2rem;
            color: rgba(255,255,255,0.75);
            font-size: 0.98rem;
        }

            .back-link a {
                color: #FFD700;
                text-decoration: none;
                font-weight: 500;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
            }

                .back-link a:hover {
                    color: white;
                    text-decoration: underline;
                }

        @@media (max-width: 480px) {
            .container {
                padding: 0 1rem;
            }

            .card {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="animated-shape shape1"></div>
        <div class="animated-shape shape2"></div>
    </div>

    <div class="container">
        <div class="logo">
            <a href="/">
                <i class="fas fa-code"></i> TeachCodIT
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h1>Сброс пароля</h1>
                <p>Введите новый пароль для вашего аккаунта</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                </div>
            }

            <form asp-action="ResetPassword" method="post" id="resetForm">
                <input type="hidden" name="token" value="@ViewBag.Token" />

                <div class="form-group">
                    <label class="form-label">Новый пароль</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="passwordUser" class="form-control" id="password" placeholder="Введите новый пароль" required minlength="6" />
                        <i class="fas fa-eye password-toggle" id="togglePassword"></i>
                    </div>
                    <div class="password-hint">
                        Минимум 6 символов, должен содержать хотя бы один спецсимвол
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Подтверждение пароля</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="confirmPassword" class="form-control" id="confirmPassword" placeholder="Повторите пароль" required />
                        <i class="fas fa-eye password-toggle" id="toggleConfirmPassword"></i>
                    </div>
                    <div id="passwordMatch"></div>
                </div>

                <button type="submit" class="btn" id="submitBtn">
                    <i class="fas fa-save"></i> Сохранить новый пароль
                </button>
            </form>

            <div class="back-link">
                <a href="@Url.Action("Authorization", "Account")">
                    <i class="fas fa-arrow-left"></i> Вернуться ко входу
                </a>
            </div>
        </div>
    </div>

    <script>
        // Показ/скрытие пароля
        document.getElementById('togglePassword').addEventListener('click', function () {
            const input = document.getElementById('password');
            const type = input.type === 'password' ? 'text' : 'password';
            input.type = type;
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });

        document.getElementById('toggleConfirmPassword').addEventListener('click', function () {
            const input = document.getElementById('confirmPassword');
            const type = input.type === 'password' ? 'text' : 'password';
            input.type = type;
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });

        // Проверка совпадения паролей
        const pwd = document.getElementById('password');
        const confirm = document.getElementById('confirmPassword');
        const matchDiv = document.getElementById('passwordMatch');

        function checkMatch() {
            if (pwd.value && confirm.value) {
                matchDiv.textContent = pwd.value === confirm.value ? '' : 'Пароли не совпадают';
            } else {
                matchDiv.textContent = '';
            }
        }

        pwd.addEventListener('input', checkMatch);
        confirm.addEventListener('input', checkMatch);

        // Предотвращение отправки + индикатор загрузки
        document.getElementById('resetForm').addEventListener('submit', function (e) {
            if (pwd.value !== confirm.value) {
                e.preventDefault();
                matchDiv.textContent = 'Пароли не совпадают';
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Сохранение...';
        });
    </script>
</body>
</html>