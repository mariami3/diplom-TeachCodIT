@model User
@{
    ViewData["Title"] = "Регистрация в TeachCodIT";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 2rem 1rem 4rem;
            position: relative;
        }

        /* Фон и анимированные фигуры */
        .background {
            position: absolute;
            inset: 0;
            background: inherit;
            z-index: 0;
        }

        .animated-shape {
            position: absolute;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            filter: blur(70px);
            pointer-events: none;
        }

        .shape1 {
            width: 500px;
            height: 500px;
            top: -150px;
            right: -150px;
            animation: float 22s infinite;
        }

        .shape2 {
            width: 400px;
            height: 400px;
            bottom: -100px;
            left: -100px;
            animation: float 18s infinite reverse;
        }

        .shape3 {
            width: 300px;
            height: 300px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: float 14s infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            33% { transform: translateY(-40px) rotate(120deg); }
            66% { transform: translateY(30px) rotate(-120deg); }
        }

        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 520px;
            margin: 1rem auto 3rem;
        }

        .logo {
            text-align: center;
            margin: 1.5rem 0 2.5rem;
        }

        .logo a {
            font-size: 2.4rem;
            font-weight: 800;
            background: linear-gradient(45deg, #fff, #f0f0f0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        .logo i {
            color: #FFD700;
            margin-right: 12px;
        }

        .card {
            background: rgba(255, 255, 255, 0.09);
            backdrop-filter: blur(12px);
            border-radius: 24px;
            padding: 2.5rem 2rem;
            border: 1px solid rgba(255, 255, 255, 0.18);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.25);
        }

        .card-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .card-header h1 {
            color: white;
            font-size: 2.1rem;
            font-weight: 700;
            margin-bottom: 0.6rem;
        }

        .card-header p {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1rem;
        }

        /* Alert Messages */
        .alert {
            background: rgba(255, 87, 87, 0.2);
            border: 1px solid rgba(255, 87, 87, 0.3);
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            color: white;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .alert i {
            color: #ff5757;
        }

        /* Form */
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.2rem;
        }

        .form-group {
            margin-bottom: 1.6rem;
        }

        .form-label {
            display: block;
            color: white;
            font-weight: 500;
            margin-bottom: 0.6rem;
            font-size: 0.95rem;
        }

        .input-group {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.55);
            font-size: 1.1rem;
        }

        .form-control {
            width: 100%;
            padding: 1rem 1rem 1rem 3.2rem;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.22);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: all 0.25s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #FFD700;
            /* Убрано изменение фона при фокусе */
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.18);
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.45);
        }

        /* Password toggle - более темный вариант */
        .password-toggle {
            position: absolute;
            right: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(0, 0, 0, 0.5);  /* Более темный цвет */
            cursor: pointer;
            font-size: 1.1rem;
            transition: color 0.3s ease;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.1); /* Легкая подсветка для читаемости */
        }

        .password-toggle:hover {
            color: #FFD700; /* При наведении становится золотым */
        }

        /* Password strength indicator */
        .password-strength {
            margin-top: 0.5rem;
            display: flex;
            gap: 0.5rem;
        }

        .strength-bar {
            flex: 1;
            height: 4px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
            transition: all 0.3s ease;
        }

        .strength-bar.weak {
            background: #ff5757;
        }

        .strength-bar.medium {
            background: #FFD700;
        }

        .strength-bar.strong {
            background: #4CAF50;
        }

        .password-hint {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.8rem;
            margin-top: 0.25rem;
            display: flex;
            justify-content: space-between;
        }

        .password-hint i {
            color: #FFD700;
            font-size: 0.7rem;
            margin-right: 4px;
        }

        .hint-item {
            display: inline-flex;
            align-items: center;
            margin-right: 12px;
        }

        .hint-item.valid i {
            color: #4CAF50;
        }

        /* Terms */
        .terms {
            margin: 1.8rem 0;
        }

        .terms-checkbox {
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
        }

        .terms-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #FFD700;
            margin-top: 2px;
        }

        .terms-checkbox a {
            color: #FFD700;
            text-decoration: none;
        }

        .terms-checkbox a:hover {
            text-decoration: underline;
        }

        /* Button */
        .btn {
            width: 100%;
            padding: 1.1rem;
            background: linear-gradient(45deg, #FFD700, #FFAA00);
            border: none;
            border-radius: 12px;
            color: #1a1a2e;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255, 215, 0, 0.35);
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        /* Links */
        .login-link,
        .back-home {
            text-align: center;
            margin-top: 1.8rem;
            color: rgba(255, 255, 255, 0.75);
            font-size: 0.98rem;
        }

        .login-link a,
        .back-home a {
            color: #FFD700;
            text-decoration: none;
            font-weight: 600;
        }

        .login-link a:hover,
        .back-home a:hover {
            text-decoration: underline;
            color: white;
        }

        /* Password match message */
        #passwordMatch {
            color: #ff6b6b;
            font-size: 0.85rem;
            margin-top: 0.4rem;
        }

        /* Responsive */
        @@media (max-width: 520px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .card {
                padding: 2rem 1.5rem;
            }

            .container {
                padding: 0 1rem;
            }

            .password-hint {
                flex-direction: column;
                gap: 0.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="animated-shape shape1"></div>
        <div class="animated-shape shape2"></div>
        <div class="animated-shape shape3"></div>
    </div>

    <div class="container">
        <div class="logo">
            <a href="/">
                <i class="fas fa-code"></i> TeachCodIT
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h1>Создать аккаунт</h1>
                <p>Присоединяйтесь к сообществу разработчиков</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                </div>
            }

            <form asp-action="Register" method="post" id="registerForm">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Логин</label>
                        <div class="input-group">
                            <i class="fas fa-user input-icon"></i>
                            <input asp-for="LoginUser" class="form-control" placeholder="Введите логин" required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <div class="input-group">
                            <i class="fas fa-envelope input-icon"></i>
                            <input asp-for="Email" type="email" class="form-control" placeholder="Введите email" required />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Пароль</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="PasswordUser" type="password" class="form-control" id="password" placeholder="Создайте пароль" required />
                        <i class="fas fa-eye password-toggle" id="togglePassword"></i>
                    </div>

                    <!-- Индикатор силы пароля -->
                    <div class="password-strength" id="passwordStrength">
                        <div class="strength-bar" id="bar1"></div>
                        <div class="strength-bar" id="bar2"></div>
                        <div class="strength-bar" id="bar3"></div>
                    </div>

                    <!-- Подсказки по паролю -->
                    <div class="password-hint">
                        <span class="hint-item" id="hintLength">
                            <i class="fas fa-circle"></i> 6+ символов
                        </span>
                        <span class="hint-item" id="hintNumber">
                            <i class="fas fa-circle"></i> цифра
                        </span>
                        <span class="hint-item" id="hintSpecial">
                            <i class="fas fa-circle"></i> спецсимвол
                        </span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Подтверждение пароля</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="confirmPassword" class="form-control" id="confirmPassword" placeholder="Повторите пароль" required />
                        <i class="fas fa-eye password-toggle" id="toggleConfirmPassword"></i>
                    </div>
                    <div id="passwordMatch"></div>
                </div>

                <div class="terms">
                    <label class="terms-checkbox">
                        <input type="checkbox" id="terms" required />
                        <span>
                            Я соглашаюсь с <a href="#">Условиями</a> и <a href="#">Политикой конфиденциальности</a>
                        </span>
                    </label>
                </div>

                <button type="submit" class="btn" id="submitBtn" disabled>
                    <span class="btn-text">
                        <i class="fas fa-user-plus"></i> Зарегистрироваться
                    </span>
                </button>
            </form>

            <div class="login-link">
                Уже есть аккаунт? <a href="@Url.Action("Authorization", "Account")">Войти</a>
            </div>

            <div class="back-home">
                <a href="@Url.Action("Index", "Home")">
                    <i class="fas fa-arrow-left"></i> На главную
                </a>
            </div>
        </div>
    </div>

    <script>
        // Toggle password visibility
        document.getElementById('togglePassword').addEventListener('click', function() {
            const input = document.getElementById('password');
            const type = input.type === 'password' ? 'text' : 'password';
            input.type = type;
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });

        document.getElementById('toggleConfirmPassword').addEventListener('click', function() {
            const input = document.getElementById('confirmPassword');
            const type = input.type === 'password' ? 'text' : 'password';
            input.type = type;
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });

        // Password strength indicator
        const password = document.getElementById('password');
        const bar1 = document.getElementById('bar1');
        const bar2 = document.getElementById('bar2');
        const bar3 = document.getElementById('bar3');
        
        const hintLength = document.getElementById('hintLength');
        const hintNumber = document.getElementById('hintNumber');
        const hintSpecial = document.getElementById('hintSpecial');

        password.addEventListener('input', function() {
            const value = this.value;
            
            // Проверка условий
            const hasLength = value.length >= 6;
            const hasNumber = /\d/.test(value);
            const hasSpecial = /[!@@#$%^&*(),.?":{}|<>]/.test(value);
            
            // Обновление подсказок
            hintLength.classList.toggle('valid', hasLength);
            hintNumber.classList.toggle('valid', hasNumber);
            hintSpecial.classList.toggle('valid', hasSpecial);
            
            // Обновление иконок в подсказках
            hintLength.querySelector('i').className = hasLength ? 'fas fa-check-circle' : 'fas fa-circle';
            hintNumber.querySelector('i').className = hasNumber ? 'fas fa-check-circle' : 'fas fa-circle';
            hintSpecial.querySelector('i').className = hasSpecial ? 'fas fa-check-circle' : 'fas fa-circle';
            
            // Обновление индикаторов
            bar1.className = 'strength-bar';
            bar2.className = 'strength-bar';
            bar3.className = 'strength-bar';
            
            if (hasLength) bar1.classList.add('weak');
            if (hasLength && hasNumber) bar2.classList.add('medium');
            if (hasLength && hasNumber && hasSpecial) bar3.classList.add('strong');
        });

        // Password match check
        const confirm = document.getElementById('confirmPassword');
        const matchMsg = document.getElementById('passwordMatch');

        function checkMatch() {
            if (password.value && confirm.value) {
                if (password.value === confirm.value) {
                    matchMsg.textContent = '✓ Пароли совпадают';
                    matchMsg.style.color = '#4CAF50';
                } else {
                    matchMsg.textContent = '✗ Пароли не совпадают';
                    matchMsg.style.color = '#ff6b6b';
                }
            } else {
                matchMsg.textContent = '';
            }
        }

        password.addEventListener('input', checkMatch);
        confirm.addEventListener('input', checkMatch);

        // Terms → enable button
        const termsCheckbox = document.getElementById('terms');
        const submitBtn = document.getElementById('submitBtn');

        termsCheckbox.addEventListener('change', function() {
            submitBtn.disabled = !this.checked;
        });

        // Form validation on submit
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            if (password.value !== confirm.value) {
                e.preventDefault();
                matchMsg.textContent = '✗ Пароли не совпадают';
                matchMsg.style.color = '#ff6b6b';
                return;
            }
            
            // Проверка сложности пароля
            const hasLength = password.value.length >= 6;
            const hasNumber = /\d/.test(password.value);
            const hasSpecial = /[!@@#$%^&*(),.?":{}|<>]/.test(password.value);
            
            if (!hasLength || !hasNumber || !hasSpecial) {
                e.preventDefault();
                alert('Пароль должен содержать минимум 6 символов, цифру и спецсимвол');
                return;
            }
        });
    </script>
</body>
</html>