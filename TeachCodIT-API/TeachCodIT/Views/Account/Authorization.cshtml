@{
    ViewData["Title"] = "Вход в TeachCodIT";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 2rem 1rem 5rem;
            position: relative;
        }

        /* Фон и анимированные фигуры */
        .background {
            position: absolute;
            inset: 0;
            background: inherit;
            z-index: 0;
        }

        .animated-shape {
            position: absolute;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 50%;
            filter: blur(70px);
            pointer-events: none;
        }

        .shape1 {
            width: 480px;
            height: 480px;
            top: -140px;
            right: -140px;
            animation: float 22s infinite;
        }

        .shape2 {
            width: 360px;
            height: 360px;
            bottom: -120px;
            left: -120px;
            animation: float 17s infinite reverse;
        }

        .shape3 {
            width: 280px;
            height: 280px;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: float 13s infinite;
        }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0) rotate(0deg);
            }

            33% {
                transform: translateY(-30px) rotate(120deg);
            }

            66% {
                transform: translateY(20px) rotate(240deg);
            }
        }

        .container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 460px;
            margin: 1.5rem auto 4rem;
            animation: slideUp 0.8s ease-out;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Logo */
        .logo {
            text-align: center;
            margin: 1.5rem 0 2.5rem;
        }

        .logo a {
            font-size: 2.4rem;
            font-weight: 800;
            background: linear-gradient(90deg, #ffffff, #f0f0f0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        .logo i {
            color: #FFD700;
            margin-right: 12px;
        }

        /* Card */
        .card {
            background: rgba(255, 255, 255, 0.09);
            backdrop-filter: blur(12px);
            border-radius: 22px;
            padding: 2.4rem 2rem;
            border: 1px solid rgba(255, 255, 255, 0.16);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.28);
        }

        .card-header {
            text-align: center;
            margin-bottom: 2.2rem;
        }

        .card-header h1 {
            color: white;
            font-size: 2.1rem;
            font-weight: 700;
            margin-bottom: 0.6rem;
        }

        .card-header p {
            color: rgba(255, 255, 255, 0.78);
            font-size: 1rem;
        }

        /* Alert Messages */
        .alert {
            background: rgba(255, 87, 87, 0.2);
            border: 1px solid rgba(255, 87, 87, 0.3);
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            color: white;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .alert i {
            color: #ff5757;
        }

        .alert-success {
            background: rgba(76, 175, 80, 0.2);
            border: 1px solid rgba(76, 175, 80, 0.3);
        }

        .alert-success i {
            color: #4CAF50;
        }

        /* Form */
        .form-group {
            margin-bottom: 1.6rem;
        }

        .form-label {
            display: block;
            color: white;
            font-weight: 500;
            margin-bottom: 0.6rem;
            font-size: 0.95rem;
        }

        .input-group {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255, 255, 255, 0.55);
            font-size: 1.15rem;
        }

        .form-control {
            width: 100%;
            padding: 1rem 1rem 1rem 3.3rem;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.22);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: all 0.25s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: #FFD700;
            /* Убрано изменение фона при фокусе */
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.18);
        }

        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.45);
        }

        /* Password toggle - более темный вариант */
        .password-toggle {
            position: absolute;
            right: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(0, 0, 0, 0.5);
            cursor: pointer;
            font-size: 1.15rem;
            transition: color 0.3s ease;
            text-shadow: 0 1px 2px rgba(255, 255, 255, 0.1);
        }

        .password-toggle:hover {
            color: #FFD700;
        }

        /* Form options */
        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 1.2rem 0 1.8rem;
            font-size: 0.92rem;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: rgba(255, 255, 255, 0.9);
        }

        .remember-me input[type="checkbox"] {
            accent-color: #FFD700;
            width: 18px;
            height: 18px;
        }

        .forgot-link {
            color: #FFD700;
            text-decoration: none;
        }

        .forgot-link:hover {
            text-decoration: underline;
        }

        /* Button */
        .btn {
            width: 100%;
            padding: 1.1rem;
            background: linear-gradient(45deg, #FFD700, #FFAA00);
            border: none;
            border-radius: 12px;
            color: #1a1a2e;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255, 215, 0, 0.35);
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        /* Divider */
        .divider {
            text-align: center;
            margin: 1.8rem 0;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.92rem;
            position: relative;
        }

        .divider::before,
        .divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: calc(50% - 60px);
            height: 1px;
            background: rgba(255, 255, 255, 0.18);
        }

        .divider::before {
            left: 0;
        }

        .divider::after {
            right: 0;
        }

        /* Social buttons */
        .social-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .social-btn {
            padding: 0.8rem;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 12px;
            color: white;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
        }

        .social-btn:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: translateY(-2px);
        }

        /* Links */
        .register-link {
            text-align: center;
            color: rgba(255, 255, 255, 0.75);
            font-size: 0.98rem;
            margin: 1.5rem 0;
        }

        .register-link a {
            color: #FFD700;
            text-decoration: none;
            font-weight: 600;
        }

        .register-link a:hover {
            text-decoration: underline;
        }

        .back-home {
            text-align: center;
            margin-top: 2rem;
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.95rem;
        }

        .back-home a {
            color: inherit;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .back-home a:hover {
            color: white;
        }

        /* Loading spinner */
        .spinner {
            display: none;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #1a1a2e;
            animation: spin 1s ease-in-out infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .btn.loading .spinner {
            display: inline-block;
        }

        .btn.loading .btn-text {
            opacity: 0.85;
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .container {
                padding: 1rem;
            }

            .card {
                padding: 1.8rem 1.4rem;
            }

            .social-buttons {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="animated-shape shape1"></div>
        <div class="animated-shape shape2"></div>
        <div class="animated-shape shape3"></div>
    </div>

    <div class="container">
        <div class="logo">
            <a href="/">
                <i class="fas fa-code"></i> TeachCodIT
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <h1>Добро пожаловать!</h1>
                <p>Войдите в свой аккаунт</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
                </div>
            }

            <form asp-action="Authorization" method="post" id="loginForm">
                <div class="form-group">
                    <label class="form-label">Логин</label>
                    <div class="input-group">
                        <i class="fas fa-user input-icon"></i>
                        <input type="text" name="loginUser" class="form-control" placeholder="Введите ваш логин" required autofocus />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Пароль</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="passwordUser" class="form-control" id="password" placeholder="Введите ваш пароль" required />
                        <i class="fas fa-eye password-toggle" id="togglePassword"></i>
                    </div>
                </div>

                <div class="form-options">
                    <label class="remember-me">
                        <input type="checkbox" name="rememberMe" />
                        <span>Запомнить меня</span>
                    </label>
                    <a href="@Url.Action("ForgotPassword", "Account")" class="forgot-link">
                        Забыли пароль?
                    </a>
                </div>

                <button type="submit" class="btn" id="submitBtn">
                    <span class="spinner"></span>
                    <span class="btn-text">
                        <i class="fas fa-sign-in-alt"></i> Войти
                    </span>
                </button>
            </form>

            <div class="divider">
                <span>или войдите через</span>
            </div>

            <div class="social-buttons">
                <button class="social-btn google" type="button" onclick="alert('Google авторизация в разработке')">
                    <i class="fab fa-google"></i> Google
                </button>
                <button class="social-btn github" type="button" onclick="alert('GitHub авторизация в разработке')">
                    <i class="fab fa-github"></i> GitHub
                </button>
            </div>

            <div class="register-link">
                Ещё нет аккаунта? <a href="@Url.Action("Register", "Account")">Зарегистрироваться</a>
            </div>

            <div class="back-home">
                <a href="@Url.Action("Index", "Home")">
                    <i class="fas fa-arrow-left"></i> На главную
                </a>
            </div>
        </div>
    </div>

    <script>
        // Показ/скрытие пароля - более темный глазик
        document.getElementById('togglePassword').addEventListener('click', function() {
            const input = document.getElementById('password');
            const type = input.type === 'password' ? 'text' : 'password';
            input.type = type;
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });

        // Индикатор загрузки при отправке формы
        document.getElementById('loginForm').addEventListener('submit', function() {
            const btn = document.getElementById('submitBtn');
            btn.classList.add('loading');
            btn.disabled = true;
        });

        // Дополнительная валидация (опционально)
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            const login = document.querySelector('input[name="loginUser"]').value.trim();
            const password = document.getElementById('password').value.trim();
            
            if (!login || !password) {
                e.preventDefault();
                alert('Пожалуйста, заполните все поля');
                return;
            }
        });
    </script>
</body>
</html>